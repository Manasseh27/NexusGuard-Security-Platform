# =============================================================
# NexusGuard Security Platform — Environment Variables
# Copy to .env and fill in values before running
# =============================================================

# Core
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_KEY_SECRET=change-me-to-a-random-64-char-string

# Database — use Docker service name inside containers
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cisco_security
DB_USER=cisco_app
DB_PASSWORD=devpassword123

# Redis — use Docker service name inside containers
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery — use Docker service names
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers (set at least one)
AI_DEFAULT_PROVIDER=ollama
AI_FALLBACK_PROVIDER=ollama
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_OLLAMA_BASE_URL=http://ollama:11434
AI_OLLAMA_MODEL=llama3.1:8b

# SIEM (optional — leave blank to disable)
SIEM_SPLUNK_HEC_URL=
SIEM_SPLUNK_HEC_TOKEN=
SIEM_SENTINEL_WORKSPACE_ID=
SIEM_SENTINEL_PRIMARY_KEY=
SIEM_ELASTIC_URL=
SIEM_ELASTIC_API_KEY=

# Feature flags
ENABLE_AI_COPILOT=true
ENABLE_SIEM_EXPORT=false
ENABLE_CONTINUOUS_MONITORING=true
ENABLE_AUTO_REMEDIATION=false
ENABLE_OPA_POLICIES=false
ENABLE_DEMO_DATA=false

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
