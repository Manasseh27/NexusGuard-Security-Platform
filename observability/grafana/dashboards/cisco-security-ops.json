{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "Cisco Security Platform — Operations",
  "uid":   "cisco-security-ops",
  "tags":  ["cisco", "security", "compliance", "networking"],
  "refresh": "30s",
  "time":    { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Fleet Compliance Score",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [
            { "color": "red",    "value": 0   },
            { "color": "orange", "value": 60  },
            { "color": "yellow", "value": 75  },
            { "color": "green",  "value": 90  }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "avg(cisco_security_compliance_score)", "legendFormat": "Avg Score", "datasource": "${DS_PROMETHEUS}" }]
    },
    {
      "id": 2, "type": "stat", "title": "HTTP RPS",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 500 }, { "color": "red", "value": 1000 }] }
      }},
      "targets": [{ "expr": "sum(rate(cisco_security_http_requests_total[1m]))", "legendFormat": "RPS", "datasource": "${DS_PROMETHEUS}" }]
    },
    {
      "id": 3, "type": "stat", "title": "Active Connections",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 200 }, { "color": "red", "value": 500 }] }
      }},
      "targets": [{ "expr": "cisco_security_active_connections", "legendFormat": "Active", "datasource": "${DS_PROMETHEUS}" }]
    },
    {
      "id": 4, "type": "stat", "title": "Device Audits/min",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "expr": "sum(rate(cisco_security_device_audits_total[1m])) * 60", "legendFormat": "Audits/min", "datasource": "${DS_PROMETHEUS}" }]
    },
    {
      "id": 5, "type": "stat", "title": "Compliance Drift Events",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
      }},
      "targets": [{ "expr": "sum(increase(cisco_security_compliance_drift_events_total[1h]))", "legendFormat": "Drifts/hr", "datasource": "${DS_PROMETHEUS}" }]
    },
    {
      "id": 6, "type": "stat", "title": "AI Requests/min",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "expr": "sum(rate(cisco_security_ai_requests_total{status='success'}[1m])) * 60", "legendFormat": "AI Req/min", "datasource": "${DS_PROMETHEUS}" }]
    },

    {
      "id": 10, "type": "timeseries", "title": "HTTP Request Duration (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(cisco_security_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "datasource": "${DS_PROMETHEUS}" },
        { "expr": "histogram_quantile(0.95, sum(rate(cisco_security_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "datasource": "${DS_PROMETHEUS}" },
        { "expr": "histogram_quantile(0.99, sum(rate(cisco_security_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "datasource": "${DS_PROMETHEUS}" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Compliance Score by Framework",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "cisco_security_compliance_score", "legendFormat": "{{framework}}", "datasource": "${DS_PROMETHEUS}" }
      ]
    },

    {
      "id": 20, "type": "timeseries", "title": "Device Audit Duration by Type",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(cisco_security_device_audit_duration_seconds_bucket[5m])) by (le, device_type))", "legendFormat": "p95 {{device_type}}", "datasource": "${DS_PROMETHEUS}" }
      ]
    },
    {
      "id": 21, "type": "timeseries", "title": "SIEM Export Rate by Platform",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "events/s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(cisco_security_siem_events_exported_total{status='success'}[1m])) by (platform)", "legendFormat": "{{platform}}", "datasource": "${DS_PROMETHEUS}" }
      ]
    },
    {
      "id": 22, "type": "timeseries", "title": "AI Provider Latency p95",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(cisco_security_ai_request_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "p95 {{provider}}", "datasource": "${DS_PROMETHEUS}" }
      ]
    },

    {
      "id": 30, "type": "table", "title": "Top Failing Compliance Rules (Last 1h)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "transformations": [{ "id": "sortBy", "options": { "fields": [{ "displayName": "Failures", "desc": true }] } }],
      "targets": [
        { "expr": "topk(10, sum(increase(cisco_security_compliance_checks_total{result='fail'}[1h])) by (framework, rule_id))", "legendFormat": "{{framework}} / {{rule_id}}", "datasource": "${DS_PROMETHEUS}", "instant": true }
      ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Worker Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } } },
      "targets": [
        { "expr": "cisco_security_worker_queue_depth", "legendFormat": "{{queue_name}}", "datasource": "${DS_PROMETHEUS}" }
      ]
    }
  ]
}
